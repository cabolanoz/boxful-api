generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentMode {
  STANDARD
  COD
}

// Could be Customer as well
type Recipient {
  fullName String
  phone    String
  email    String?
  address  String
  city     String?
  notes    String?
}

type PackageItem {
  description String
  quantity    Int    @default(1)
  weightKg    Float?
  lengthCm    Float?
  widthCm     Float?
  heightCm    Float?
}

type SettlementSnapshot {
  shippingCostCents    Int
  codCommissionCents   Int
  collectedAmountCents Int
  merchantPayoutCents  Int
  calculatedAt         DateTime
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

model Order {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  trackingCode String @unique

  recipient Recipient
  packages  PackageItem[]

  status      OrderStatus @default(PENDING)
  paymentMode PaymentMode @default(STANDARD)

  codExpectedAmountCents  Int?
  codCollectedAmountCents Int?

  settlement SettlementSnapshot?

  deliveredAt DateTime?
  paidAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@index([paymentMode])
}

model ShippingRate {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  dayOfWeek     Int      @unique
  baseCostCents Int
  currency      String   @default("USD")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
